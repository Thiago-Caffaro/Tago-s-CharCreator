# ── Required ──────────────────────────────────────────────────────────────────
# Your OpenRouter API key  →  https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Optional: model & generation settings ────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-sonnet-4-5
PREFERRED_PROVIDER=
MAX_TOKENS=8192
TEMPERATURE=1.0
TOP_P=0.999

# ── Optional: server settings ─────────────────────────────────────────────────
# Port the frontend will be served on (default: 3000)
FRONTEND_PORT=3000

# Database path inside the container (uses the named volume — don't change unless you know what you're doing)
DATABASE_URL=sqlite:///./data/tagosCharCreator.db
